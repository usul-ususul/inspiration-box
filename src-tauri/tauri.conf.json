{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "inspiration box",
  "version": "0.1.0",
  "identifier": "com.verba-vista.inspiration-inbox",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "inspiration box",
        "width": 220,
        "height": 44,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {},
    "useLocalToolsDir": true
  }
}
